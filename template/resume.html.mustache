<!doctype html>
<html lang="en" data-theme="dark">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="color-scheme" content="dark light" />
<title>{{name}} - {{title}}</title>
<meta name="description" content="{{summary}}" />
<meta property="og:title" content="{{name}} - {{title}}" />
<meta property="og:description" content="{{tagline}}" />
<meta property="og:type" content="website" />
{{#photo}}<meta property="og:image" content="{{photo}}" />{{/photo}}{{^photo}}{{#github.user.avatar_url}}<meta property="og:image" content="{{github.user.avatar_url}}" />{{/github.user.avatar_url}}{{/photo}}
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='8' fill='%232563eb'/%3E%3Ctext x='16' y='22' font-family='Inter,sans-serif' font-weight='800' font-size='18' fill='white' text-anchor='middle'%3EAW%3C/text%3E%3C/svg%3E" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="resume.css" />
</head>
<body>

<canvas id="bg-fx" class="bg-fx no-print" aria-hidden="true"></canvas>

<nav class="nav no-print">
  <div class="nav-inner">
    <button class="nav-toggle icon-btn" id="nav-toggle" type="button"
            aria-label="Open menu" aria-expanded="false" aria-controls="nav-links">
      <svg class="i-menu" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      <svg class="i-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M6 6l12 12M18 6L6 18"/></svg>
    </button>
    <div class="nav-links" id="nav-links">
      <a href="#top">About</a>
      <a href="#stats">Activity</a>
      <a href="#experience">Experience</a>
      <a href="#projects">Projects</a>
      <a href="#open-source">Open Source</a>
      <a href="#skills">Skills</a>
      <a href="#education">Education</a>
    </div>
    <div class="nav-actions">
      <button class="icon-btn" id="theme-toggle" type="button" aria-label="Toggle theme" title="Toggle theme">
        <svg class="i-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
        <svg class="i-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
      <a class="btn btn-ghost" href="resume.docx" download>DOCX</a>
      <a class="btn btn-primary" href="resume.pdf" download>Download PDF</a>
    </div>
  </div>
  <div class="nav-scrim" id="nav-scrim" aria-hidden="true"></div>
</nav>

<main id="top">

<section class="hero">
  <div class="hero-grid">
    <div class="hero-text reveal">
      <p class="kicker">{{tagline}}</p>
      <h1>{{name}}</h1>
      <p class="role">{{title}}</p>
      <p class="lede">{{summary}}</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="resume.pdf" download>
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download PDF
        </a>
        <a class="btn btn-ghost" href="resume.docx" download>Download DOCX</a>
        {{#github.user.html_url}}<a class="btn btn-ghost" href="{{github.user.html_url}}" target="_blank" rel="noopener">GitHub →</a>{{/github.user.html_url}}
        <a class="btn btn-ghost" href="mailto:{{email}}">Email</a>
      </div>
      <div class="hero-meta">
        <span>{{location}}</span>
        <span><a href="mailto:{{email}}">{{email}}</a></span>
      </div>

      {{#badges.length}}
      <ul class="badges no-print" role="list">
        {{#badges}}
        <li>
          <a class="badge badge--{{id}}" href="{{href}}" {{#download}}download{{/download}} {{^download}}target="_blank" rel="noopener"{{/download}}>
            <svg class="badge-fx" viewBox="0 0 220 64" preserveAspectRatio="none" aria-hidden="true" focusable="false">
              <defs>
                <path id="bp-{{id}}" d="M 12 1.5 H 208 A 10.5 10.5 0 0 1 218.5 12 V 52 A 10.5 10.5 0 0 1 208 62.5 H 12 A 10.5 10.5 0 0 1 1.5 52 V 12 A 10.5 10.5 0 0 1 12 1.5 Z" fill="none"/>
                <linearGradient id="bg-{{id}}" x1="0" y1="0" x2="1" y2="1">
                  <stop offset="0%" stop-color="var(--badge-a)"/>
                  <stop offset="100%" stop-color="var(--badge-b)"/>
                </linearGradient>
              </defs>
              <use href="#bp-{{id}}" stroke="url(#bg-{{id}})" stroke-width="1.25" stroke-opacity="0.55" vector-effect="non-scaling-stroke"/>
              <use href="#bp-{{id}}" stroke="url(#bg-{{id}})" stroke-width="2" stroke-dasharray="60 480" vector-effect="non-scaling-stroke">
                <animate attributeName="stroke-dashoffset" from="0" to="-540" dur="6s" repeatCount="indefinite"/>
              </use>
              <circle r="1.8" fill="var(--badge-a)"><animateMotion dur="5s" repeatCount="indefinite" rotate="auto"><mpath href="#bp-{{id}}"/></animateMotion></circle>
              <circle r="1.4" fill="var(--badge-b)"><animateMotion dur="5s" begin="-1.25s" repeatCount="indefinite" rotate="auto"><mpath href="#bp-{{id}}"/></animateMotion></circle>
              <circle r="1.2" fill="var(--badge-a)" opacity="0.75"><animateMotion dur="5s" begin="-2.5s" repeatCount="indefinite" rotate="auto"><mpath href="#bp-{{id}}"/></animateMotion></circle>
              <circle r="1" fill="var(--badge-b)" opacity="0.7"><animateMotion dur="5s" begin="-3.75s" repeatCount="indefinite" rotate="auto"><mpath href="#bp-{{id}}"/></animateMotion></circle>
            </svg>
            <span class="badge-content">
              <span class="badge-icon">{{{iconSvg}}}</span>
              <span class="badge-body">
                <span class="badge-val">{{value}}</span>
                <span class="badge-lbl">{{label}}</span>
              </span>
            </span>
          </a>
        </li>
        {{/badges}}
      </ul>
      {{/badges.length}}
    </div>

    <aside class="hero-card reveal" id="about">
      {{#photo}}<img class="avatar" src="{{photo}}" alt="{{name}}" />{{/photo}}
      {{^photo}}{{#github.user.avatar_url}}<img class="avatar" src="{{github.user.avatar_url}}" alt="{{name}}" />{{/github.user.avatar_url}}{{/photo}}
      <div class="stats">
        <div class="stat"><span class="num">{{github.totals.repos}}</span><span class="lbl">Repos</span></div>
        <div class="stat"><span class="num">{{github.totals.stars}}</span><span class="lbl">Stars</span></div>
        <div class="stat"><span class="num">{{github.user.followers}}</span><span class="lbl">Followers</span></div>
      </div>
      <div class="card-links">
        {{#github.user.html_url}}<a href="{{github.user.html_url}}" target="_blank" rel="noopener">github.com/{{ghUser}} →</a>{{/github.user.html_url}}
      </div>
    </aside>
  </div>
</section>

{{#github.user}}
<section class="block no-print" id="stats">
  <div class="block-head reveal">
    <span class="eyebrow">≡</span>
    <h2>GitHub Activity <span class="head-sub">live</span></h2>
  </div>
  <div class="stat-cards reveal">
    <div class="stat-card stat-card--wide">
      <img alt="GitHub stats for {{ghUser}}"
           loading="lazy"
           src="https://github-readme-stats.vercel.app/api?username={{ghUser}}&show_icons=true&hide_rank=true&hide_border=true&hide_title=true&hide=stars&card_width=520&bg_color=00000000&title_color=60a5fa&text_color=c9cfdb&icon_color=60a5fa"/>
    </div>
    <div class="stat-card stat-card--wide">
      <img alt="GitHub streak for {{ghUser}}"
           loading="lazy"
           src="https://streak-stats.demolab.com/?user={{ghUser}}&hide_border=true&background=00000000&stroke=00000000&ring=60a5fa&fire=3b82f6&currStreakLabel=60a5fa&sideLabels=8a93a4&currStreakNum=e6e9f1&sideNums=e6e9f1&dates=8a93a4"/>
    </div>
    <div class="stat-card stat-card--mini">
      <span class="sc-num">{{github.totals.stars}}</span>
      <span class="sc-lbl">Total Stars</span>
      <span class="sc-sub">incl. <a href="https://github.com/bbrown430/plex-poster-set-helper" target="_blank" rel="noopener">plex-poster-set-helper</a> (lead contributor)</span>
    </div>
    <div class="stat-card stat-card--mini">
      <span class="sc-num">{{github.user.followers}}</span>
      <span class="sc-lbl">Followers</span>
      <span class="sc-sub">{{github.user.following}} following</span>
    </div>
  </div>
  <div class="stat-card stat-card--graph reveal">
    <img alt="Contribution graph for {{ghUser}}"
         loading="lazy"
         src="https://ghchart.rshah.org/2563eb/{{ghUser}}"/>
  </div>
</section>
{{/github.user}}

<section class="block" id="experience">
  <div class="block-head reveal">
    <span class="eyebrow">01</span>
    <h2>Experience</h2>
  </div>
  <div class="timeline">
    {{#experience}}
    <article class="job reveal">
      <div class="job-time">
        <span class="dot"></span>
        <span class="when">{{start}} – {{end}}</span>
      </div>
      <div class="job-body">
        <h3>{{role}} <span class="at">@ {{company}}</span></h3>
        <p class="meta">{{location}}</p>
        <ul>
          {{#highlights}}<li>{{.}}</li>{{/highlights}}
        </ul>
      </div>
    </article>
    {{/experience}}
  </div>
</section>

<section class="block" id="projects">
  <div class="block-head reveal">
    <span class="eyebrow">02</span>
    <h2>Selected Projects</h2>
  </div>
  <div class="grid grid-2">
    {{#projects}}
    <a class="card project reveal" href="{{url}}" target="_blank" rel="noopener">
      <div class="card-row">
        {{#icon}}<img class="card-icon" src="{{icon}}" alt="" loading="lazy" data-initial="{{initial}}" onerror="const s=document.createElement('span');s.className='card-icon letter';s.textContent=this.dataset.initial;this.replaceWith(s);" />{{/icon}}
        {{^icon}}<span class="card-icon letter">{{initial}}</span>{{/icon}}
        <div class="card-body">
          <h3>{{name}} <span class="arrow">↗</span></h3>
          <p>{{blurb}}</p>
        </div>
      </div>
    </a>
    {{/projects}}
  </div>
</section>

{{#github.repos.length}}
<section class="block no-print" id="open-source">
  <div class="block-head reveal">
    <span class="eyebrow">03</span>
    <h2>From GitHub <span class="head-sub">live</span></h2>
  </div>
  <div class="grid grid-3" id="repos">
    {{#github.repos}}
    <a class="card repo reveal" href="{{url}}" target="_blank" rel="noopener">
      <div class="card-row">
        {{#icon}}<img class="card-icon" src="{{icon}}" alt="" loading="lazy" data-initial="{{initial}}" onerror="const s=document.createElement('span');s.className='card-icon letter';s.textContent=this.dataset.initial;this.replaceWith(s);" />{{/icon}}
        {{^icon}}<span class="card-icon letter">{{initial}}</span>{{/icon}}
        <div class="card-body">
          <div class="repo-head">
            <h3>{{name}}</h3>
            <span class="arrow">↗</span>
          </div>
          <p class="repo-desc">{{description}}</p>
          <div class="repo-meta">
            {{#language}}<span class="tag lang" data-lang="{{language}}"><span class="dot"></span>{{language}}</span>{{/language}}
            <span class="tag">★ {{stars}}</span>
            {{#forks}}<span class="tag">⑂ {{forks}}</span>{{/forks}}
          </div>
        </div>
      </div>
    </a>
    {{/github.repos}}
  </div>
</section>
{{/github.repos.length}}

<section class="block" id="skills">
  <div class="block-head reveal">
    <span class="eyebrow">04</span>
    <h2>Skills &amp; Stack</h2>
  </div>
  <div class="skills">
    {{#skills}}
    <div class="skill-row reveal">
      <span class="skill-label">{{group}}</span>
      <span class="skill-items">
        {{#items}}<span class="chip">{{.}}</span>{{/items}}
      </span>
    </div>
    {{/skills}}
  </div>
</section>

<section class="block" id="education">
  <div class="block-head reveal">
    <span class="eyebrow">05</span>
    <h2>Education</h2>
  </div>
  {{#education}}
  <article class="edu reveal">
    <div class="job-time">
      <span class="dot"></span>
      <span class="when">{{start}} – {{end}}</span>
    </div>
    <div class="job-body">
      <h3>{{degree}} <span class="at">@ {{school}}</span></h3>
      <p class="meta">{{location}}</p>
      {{#notes.length}}<ul>{{#notes}}<li>{{.}}</li>{{/notes}}</ul>{{/notes.length}}
    </div>
  </article>
  {{/education}}
</section>

<footer class="footer no-print">
  <div>© <span id="year"></span> {{name}}</div>
  <div class="foot-links">
    <a href="resume.pdf" download>PDF</a>
    <a href="resume.docx" download>DOCX</a>
    {{#github.user.html_url}}<a href="{{github.user.html_url}}" target="_blank" rel="noopener">GitHub</a>{{/github.user.html_url}}
    <a href="mailto:{{email}}">Email</a>
  </div>
</footer>

</main>

<script src="resume.js" defer></script>
</body>
</html>
